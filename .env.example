# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/contract_analyzer

# JWT Authentication
SECRET_KEY=your-super-secret-jwt-key-here-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# File Storage
UPLOAD_DIRECTORY=./uploads
MAX_FILE_SIZE_MB=50

# Development Settings
DEBUG=true
SQL_DEBUG=false

# Optional: Cloud Storage (for production)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_S3_BUCKET=your_bucket_name
# AWS_REGION=us-east-1

# Optional: Digital Ocean Spaces
# DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# DO_SPACES_KEY=your_spaces_key
# DO_SPACES_SECRET=your_spaces_secret
# DO_SPACES_BUCKET=your_bucket_name

# Optional: Email Configuration (for notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_app_password